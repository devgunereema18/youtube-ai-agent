# ==============================================
# AI Video Agent - Configuration
# ==============================================

# VidIQ API Key (get from https://vidiq.com/mcp/)
VIDIQ_API_KEY=your_vidiq_api_key_here

# HeyGen API Key (get from https://app.heygen.com/settings?nav=API)
HEYGEN_API_KEY=your_heygen_api_key_here

# YouTube OAuth2 Credentials (from Google Cloud Console)
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here

# OpenAI API Key (for script enhancement - optional)
OPENAI_API_KEY=your_openai_api_key_here

# HeyGen Avatar Configuration
HEYGEN_AVATAR_ID=default
HEYGEN_VOICE_ID=default

# YouTube Channel Settings
YOUTUBE_CATEGORY_ID=22
YOUTUBE_DEFAULT_PRIVACY=private
